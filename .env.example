# ┌─────────────────────────────────────────────────────────────┐
# │  Local AI Stack — Configuration                            │
# │                                                            │
# │  Copy this file to .env and edit as needed:                │
# │    cp .env.example .env                                    │
# │                                                            │
# │  After making changes, restart the stack:                  │
# │    ./start.sh                                              │
# └─────────────────────────────────────────────────────────────┘

# ── Ollama mode ───────────────────────────────────
# "native"  = Ollama runs on your Mac with GPU acceleration (fast!)
# "docker"  = Ollama runs in Docker, CPU-only but fully isolated
OLLAMA_MODE=native

# How long Ollama keeps a model loaded in GPU memory after the last request.
# Critical on M4 16 GB: a resident chat model (e.g. qwen2.5-coder:14b ~11 GB)
# will starve FLUX (~12 GB peak) and cause kIOGPUCommandBufferCallbackError
# OutOfMemory → noise-grid output. Short = chat eviction soon after each
# message (pay ~5–10 s reload tax on follow-up turns) so the GPU is free
# when you switch to image gen. Larger = better chat latency, higher OOM risk.
# Applied via local.ollama.server.plist — re-run ./start.sh after changes.
OLLAMA_KEEP_ALIVE=30s

# ── Resources (docker mode only) ─────────────────
# How much CPU and memory the Ollama container is allowed to use.
# Ignored in native mode — Ollama uses your system resources directly.
OLLAMA_CPUS=4
OLLAMA_MEMORY=12g
WEBUI_CPUS=1
WEBUI_MEMORY=1g

# Example: dedicated Mac mini AI server (no other workloads, leave ~2 GB
# headroom for macOS). Uncomment and adjust for a beefier host.
# OLLAMA_CPUS=10
# OLLAMA_MEMORY=14g

# ── Ports (host-side) ────────────────────────────
# Chat UI (HTTP):  http://localhost:3000
# Chat UI (HTTPS): https://localhost  (port 443, requires mkcert, see start.sh)
WEBUI_PORT=3000
WEBUI_SSL_PORT=443

# ── Optional bind mounts (uncomment to enable) ────
# SHARED_FOLDER=./workspace
# SSH_KEY_PATH=~/.ssh
# GIT_CONFIG_PATH=~/.gitconfig

# ── Image generation ─────────────────────────────
# When true, start.sh launches an image generation backend on the host and
# wires Open WebUI to use it via host.docker.internal.
ENABLE_IMAGE_GENERATION=true

# Which backend to use:
#   "comfyui"     = ComfyUI + FLUX.1-dev Q4_K_S GGUF (~3–6 min/image at 1024×1024,
#                   ~12 GB of assets auto-downloaded on first run, MPS-accelerated).
#   "drawthings"  = Draw Things + FLUX via A1111 proxy (faster, less memory).
#                   Requires Draw Things installed from the App Store with the
#                   API server enabled: Settings → Advanced → API Server (port 7860).
IMAGE_GEN_BACKEND=comfyui

# ── ComfyUI settings (IMAGE_GEN_BACKEND=comfyui) ─
COMFYUI_PORT=8188

# Where ComfyUI is installed and which Python builds its venv.
# Defaults work on a fresh Apple Silicon Mac with `brew install python@3.12`.
# COMFYUI_DIR=$HOME/ComfyUI
# COMFYUI_PYTHON=python3.12
# COMFYUI_LOG=$HOME/ComfyUI/comfyui.log

# To skip the auto-download of FLUX assets (e.g. metered connection,
# bring-your-own quant), touch the marker file before first run:
#   touch $HOME/ComfyUI/models/.skip_flux_download
# Then place these files yourself:
#   $COMFYUI_DIR/models/unet/flux1-dev-Q4_K_S.gguf
#   $COMFYUI_DIR/models/clip/clip_l.safetensors
#   $COMFYUI_DIR/models/clip/t5xxl_fp8_e4m3fn.safetensors
#   $COMFYUI_DIR/models/vae/ae.safetensors

# ── Optional LoRA on top of FLUX ──────────────────
# Drop FLUX-compatible .safetensors LoRA files into:
#   $COMFYUI_DIR/models/loras/
# Then set FLUX_LORA_NAME to the filename (just the name, no path) and
# re-run ./start.sh. The patcher injects a LoraLoaderModelOnly node
# into the WebUI workflow between UnetLoaderGGUF and the sampler.
# Leave empty to disable.
# FLUX_LORA_NAME=my-style.safetensors
# FLUX_LORA_STRENGTH=0.8

# ── Periodic cleanup (cleanup-media.sh) ────────────
# A launchd agent installed by start.sh fires every hour and runs
# cleanup-media.sh. It surgically removes WebUI `file` rows that are
# no longer referenced by any chat (plus their bytes on disk), and any
# dangling chat_file rows pointing at deleted chats.
# It does NOT touch ~/ComfyUI/output/ — those are the full-quality
# originals (WebUI stores re-encoded lossy copies), so there's no
# byte-level correlation to "orphan" them surgically. Manage that
# directory by hand if disk grows.
# Preview without changes: ./cleanup-media.sh --dry-run
# Disable the scheduler:   launchctl unload ~/Library/LaunchAgents/local.ai-stack.cleanup-media.plist

# ── Draw Things settings (IMAGE_GEN_BACKEND=drawthings) ─
# Port Draw Things API server listens on (set in Draw Things → Settings → Advanced)
# DRAW_THINGS_PORT=7860
# Port the A1111 proxy shim listens on (Open WebUI connects to this)
# DRAW_THINGS_PROXY_PORT=7861
# Default model filename as it appears in Draw Things' model list
# DRAW_THINGS_DEFAULT_MODEL=flux_1_dev_q4p.ckpt

