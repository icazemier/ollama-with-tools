# ┌─────────────────────────────────────────────────────────────┐
# │  Local AI Stack — Configuration                            │
# │                                                            │
# │  Copy this file to .env and edit as needed:                │
# │    cp .env.example .env                                    │
# │                                                            │
# │  After making changes, restart the stack:                  │
# │    ./start.sh                                              │
# └─────────────────────────────────────────────────────────────┘

# ── Ollama mode ───────────────────────────────────
# "native"  = Ollama runs on your Mac with GPU acceleration (fast!)
# "docker"  = Ollama runs in Docker, CPU-only but fully isolated
OLLAMA_MODE=native

# ── Resources (docker mode only) ─────────────────
# How much CPU and memory the Ollama container is allowed to use.
# Ignored in native mode — Ollama uses your system resources directly.
OLLAMA_CPUS=4
OLLAMA_MEMORY=12g
WEBUI_CPUS=1
WEBUI_MEMORY=1g

# Example: dedicated Mac mini AI server (no other workloads, leave ~2 GB
# headroom for macOS). Uncomment and adjust for a beefier host.
# OLLAMA_CPUS=10
# OLLAMA_MEMORY=14g

# ── Ports (host-side) ────────────────────────────
# Chat UI (HTTP):  http://localhost:3000
# Chat UI (HTTPS): https://localhost  (port 443, requires mkcert, see start.sh)
WEBUI_PORT=3000
WEBUI_SSL_PORT=443

# ── Optional bind mounts (uncomment to enable) ────
# SHARED_FOLDER=./workspace
# SSH_KEY_PATH=~/.ssh
# GIT_CONFIG_PATH=~/.gitconfig

# ── Image generation ─────────────────────────────
# Set to false to skip image gen entirely (no ComfyUI, no bridge container).
ENABLE_IMAGE_GENERATION=true

# Backend that powers image generation:
#
#   ollama   — Ollama's native image models (x/flux2-klein, x/z-image-turbo)
#              served via a tiny FastAPI bridge that exposes an OpenAI-compatible
#              /v1/images/generations endpoint to Open WebUI. Dead simple — no
#              extra Python venv, no MPS dtype issues. macOS only (Ollama
#              upstream limitation) and requires OLLAMA_MODE=native.
#
#   comfyui  — ComfyUI in a venv on the host with SDXL/Flux .safetensors.
#              More flexible (any workflow, any custom node) but more moving
#              parts. Use this on Linux or if you need ComfyUI's flexibility.
#
# Auto-detect (when IMAGE_BACKEND is unset): existing ~/ComfyUI install →
# comfyui, otherwise ollama. Set explicitly to override the detection.
# IMAGE_BACKEND=ollama

# Which model to use. Semantics depend on IMAGE_BACKEND:
#
# ── For IMAGE_BACKEND=ollama (Ollama tag, will be pulled automatically) ──
#   x/flux2-klein:4b      — 5.7 GB, Apache 2.0, fits 16 GB Mac comfortably
#   x/flux2-klein:9b      — 12 GB, FLUX Non-Commercial v2.1
#   x/z-image-turbo:fp8   — 13 GB, Apache 2.0 (tight on 16 GB Macs)
#   x/z-image-turbo:bf16  — 33 GB, Apache 2.0 (needs 32 GB+ Mac)
#
# ── For IMAGE_BACKEND=comfyui (preset → checkpoint download + workflow) ──
#   sdxl          — SDXL base 1.0 (~6.5 GB, cfg=7, 20 steps, scheduler=normal)
#   flux-schnell  — Flux.1 schnell fp8 (~17 GB, cfg=1, 4 steps,  scheduler=simple)
#                   Apache-2.0, ungated. (Note: fp8 fails on Apple Silicon MPS.)
#   flux-dev      — Flux.1 dev fp8 (~17 GB, cfg=1, 20 steps, scheduler=simple)
#                   Non-commercial license, gated — needs HF_TOKEN below.
#
# Default per backend: ollama → x/flux2-klein:4b, comfyui → sdxl.
# IMAGE_MODEL=x/flux2-klein:4b

# ── ComfyUI-only settings (ignored when IMAGE_BACKEND=ollama) ───
COMFYUI_PORT=8188

# HuggingFace token, required only for flux-dev. Accept the license at
# https://huggingface.co/black-forest-labs/FLUX.1-dev first.
# HF_TOKEN=hf_xxx

# Where ComfyUI is installed and which Python builds its venv.
# Defaults work on a fresh Apple Silicon Mac with `brew install python@3.12`.
# COMFYUI_DIR=$HOME/ComfyUI
# COMFYUI_PYTHON=python3.12
# COMFYUI_LOG=$HOME/ComfyUI/comfyui.log

# Direct override of the checkpoint filename + URL. Set these to drop in any
# .safetensors compatible with CheckpointLoaderSimple — bypasses IMAGE_MODEL's
# default. Place the file in $COMFYUI_DIR/models/checkpoints/ if it's already
# downloaded.
# COMFYUI_DEFAULT_MODEL_NAME=sd_xl_base_1.0.safetensors
# COMFYUI_DEFAULT_MODEL_URL=https://huggingface.co/stabilityai/stable-diffusion-xl-base-1.0/resolve/main/sd_xl_base_1.0.safetensors

