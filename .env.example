# ┌─────────────────────────────────────────────────────────────┐
# │  Local AI Stack — Configuration                            │
# │                                                            │
# │  Copy this file to .env and edit as needed:                │
# │    cp .env.example .env                                    │
# │                                                            │
# │  After making changes, restart the stack:                  │
# │    ./start.sh                                              │
# └─────────────────────────────────────────────────────────────┘

# ── Ollama mode ───────────────────────────────────
# "native"  = Ollama runs on your Mac with GPU acceleration (fast!)
# "docker"  = Ollama runs in Docker, CPU-only but fully isolated
OLLAMA_MODE=native

# ── Resources (docker mode only) ─────────────────
# How much CPU and memory the Ollama container is allowed to use.
# Ignored in native mode — Ollama uses your system resources directly.
OLLAMA_CPUS=4
OLLAMA_MEMORY=12g
WEBUI_CPUS=1
WEBUI_MEMORY=1g
SANDBOX_CPUS=2
SANDBOX_MEMORY=4g

# ── Ports (host-side) ────────────────────────────
# Which port to open on your machine for the chat UI.
# Visit http://localhost:3000 (or your custom port) in a browser.
WEBUI_PORT=3000

# ── Shared folder ────────────────────────────────
# Mount a folder from your machine into the sandbox container.
# This is the ONLY folder visible to the sandbox — the AI cannot
# see anything else on your system. Great for sharing project
# files you want to work on inside the sandbox.
#
# Can be a relative path (./workspace) or absolute (/Users/you/projects).
# The folder is created automatically if it doesn't exist.
#
# Uncomment to enable:
# SHARED_FOLDER=./workspace

# ── Git / SSH ─────────────────────────────────────
# Mount your SSH keys and git config into the sandbox (read-only)
# so you can clone, push, and pull repos from inside the container.
# The sandbox can USE your keys but cannot modify them.
#
# Uncomment to enable:
# SSH_KEY_PATH=~/.ssh
# GIT_CONFIG_PATH=~/.gitconfig
